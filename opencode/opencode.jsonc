{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "enabled": true,
    },
    "exa-search": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true,
    },
    "fff": {
      "type": "local",
      "command": ["fff-mcp"],
      "enabled": true,
    },
  },
  "disabled_providers": [],
  "provider": {
    "bifrost": {
      "name": "Personal BiFront",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://bifrost.dropbear-tortoise.ts.net/v1/chat/completions"
      },
      "models": {
        "openrouter/kimi-k2.5": {
          "name": "Kimi K2.5"
        }
      }
    }
  },
}
