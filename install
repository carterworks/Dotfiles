#!/usr/bin/env bash

set -euo pipefail

CONFIG="install.conf.yaml"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v nix >/dev/null 2>&1; then
  printf 'nix is required to run this installer.\nInstall it from: https://nixos.org/download/\n' >&2
  exit 1
fi

cd "${BASEDIR}"
exec nix run ".#dotbot" -- -v -d "${BASEDIR}" -c "${CONFIG}" "$@"
