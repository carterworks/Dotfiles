#!/usr/bin/env bash

set -euo pipefail

CONFIG="install.conf.yaml"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

has_gum() {
  command -v gum >/dev/null 2>&1
}

log_message() {
  local level="$1"
  shift

  if has_gum; then
    gum log --level "${level}" "$*"
  else
    case "${level}" in
      error|warn)
        printf '%s\n' "$*" >&2
        ;;
      *)
        printf '%s\n' "$*"
        ;;
    esac
  fi
}

section() {
  local title="$1"

  if has_gum; then
    gum style --bold --foreground 255 --background 62 --padding "0 1" --margin "1 0" "${title}"
  else
    printf '\n== %s ==\n' "${title}"
  fi
}

show_log() {
  local logfile="$1"

  if [[ -s "${logfile}" ]]; then
    printf '\n' >&2
    cat "${logfile}" >&2
  fi
}

run_quiet_step() {
  local title="$1"
  shift

  local logfile
  local pid
  local status=0

  logfile="$(mktemp "${TMPDIR:-/tmp}/dotfiles-install.XXXXXX")"
  "$@" >"${logfile}" 2>&1 &
  pid=$!

  if has_gum; then
    gum spin --spinner dot --title "${title}" -- bash -c 'pid="$1"; while kill -0 "$pid" 2>/dev/null; do sleep 0.1; done' _ "${pid}"
  else
    log_message info "${title}"
  fi

  if ! wait "${pid}"; then
    status=$?
  fi

  if (( status == 0 )); then
    rm -f "${logfile}"
    log_message info "${title} complete"
    return 0
  fi

  log_message error "${title} failed"
  show_log "${logfile}"
  rm -f "${logfile}"
  return "${status}"
}

warn_if_git_dirty() {
  if command -v git >/dev/null 2>&1 && [[ -n "$(git -C "${BASEDIR}" status --short 2>/dev/null)" ]]; then
    log_message warn "Git tree is dirty; Nix may warn during evaluation"
  fi
}

if ! command -v nix >/dev/null 2>&1; then
  log_message error "nix is required to run this installer"
  log_message info "Install it from: https://github.com/DeterminateSystems/nix-installer"
  exit 1
fi

run_dotbot() {
  nix run ".#dotbot" -- --verbose --base-directory "${BASEDIR}" --config-file "${CONFIG}" "$@"
}

current_machine_name() {
  local name

  case "$(uname -s)" in
    Darwin)
      if command -v scutil >/dev/null 2>&1; then
        name="$(scutil --get LocalHostName 2>/dev/null || true)"
      fi
      ;;
    Linux)
      if command -v hostnamectl >/dev/null 2>&1; then
        name="$(hostnamectl --static 2>/dev/null || true)"
      fi
      if [[ -z "${name:-}" && -r /etc/hostname ]]; then
        IFS= read -r name < /etc/hostname
      fi
      ;;
  esac

  if [[ -z "${name:-}" ]]; then
    name="$(hostname)"
    name="${name%%.*}"
  fi

  if [[ -z "${name}" ]]; then
    printf 'Could not determine machine name.\n' >&2
    exit 1
  fi

  printf '%s\n' "${name}"
}

run_rebuild() {
  local rebuild
  local machine_name

  machine_name="$(current_machine_name)"

  case "$(uname -s)" in
    Darwin)
      rebuild="$(command -v darwin-rebuild || true)"
      if [[ -z "${rebuild}" ]]; then
        printf 'darwin-rebuild is required on nix-darwin systems.\n' >&2
        exit 1
      fi

      sudo "${rebuild}" switch --flake "${BASEDIR}#${machine_name}"
      ;;
    Linux)
      if [[ ! -e /etc/NIXOS && ! -e /run/current-system/nixos-version ]]; then
        printf 'Unsupported Linux system; expected NixOS.\n' >&2
        exit 1
      fi

      rebuild="$(command -v nixos-rebuild || true)"
      if [[ -z "${rebuild}" ]]; then
        printf 'nixos-rebuild is required on NixOS systems.\n' >&2
        exit 1
      fi

      sudo "${rebuild}" switch --flake "${BASEDIR}#${machine_name}"
      ;;
    *)
      printf 'Unsupported system: %s\n' "$(uname -s)" >&2
      exit 1
      ;;
  esac
}

cd "${BASEDIR}"
section "Dotfiles install"
log_message info "Machine: $(current_machine_name)"
log_message info "System: $(uname -s)"
warn_if_git_dirty

section "Apply dotfiles"
run_quiet_step "Running dotbot" run_dotbot "$@"

section "Rebuild system"
log_message info "Starting system rebuild"
run_rebuild
log_message info "System rebuild complete"
