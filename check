#!/usr/bin/env bash

set -euo pipefail

CONFIG="install.conf.yaml"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v nix >/dev/null 2>&1; then
  printf 'nix is required to run this checker.\nInstall it from: https://github.com/DeterminateSystems/nix-installer\n' >&2
  exit 1
fi

run_dotbot_check() {
  nix run ".#dotbot" -- --verbose --exit-on-failure --dry-run --base-directory "${BASEDIR}" --config-file "${CONFIG}" "$@"
}

current_machine_name() {
  local name

  case "$(uname -s)" in
    Darwin)
      if command -v scutil >/dev/null 2>&1; then
        name="$(scutil --get LocalHostName 2>/dev/null || true)"
      fi
      ;;
    Linux)
      if command -v hostnamectl >/dev/null 2>&1; then
        name="$(hostnamectl --static 2>/dev/null || true)"
      fi
      if [[ -z "${name:-}" && -r /etc/hostname ]]; then
        IFS= read -r name < /etc/hostname
      fi
      ;;
  esac

  if [[ -z "${name:-}" ]]; then
    name="$(hostname)"
    name="${name%%.*}"
  fi

  if [[ -z "${name}" ]]; then
    printf 'Could not determine machine name.\n' >&2
    exit 1
  fi

  printf '%s\n' "${name}"
}

verify_darwin_build() {
  local machine_name
  local output

  machine_name="$(current_machine_name)"
  output="$(nix build --print-out-paths --no-link "${BASEDIR}#darwinConfigurations.\"${machine_name}\".system")"

  [[ -d "${output}/sw" ]]
  [[ -x "${output}/sw/bin/darwin-rebuild" ]]
  [[ -x "${output}/sw/bin/nix" ]]
}

verify_nixos_build() {
  local machine_name
  local output

  machine_name="$(current_machine_name)"
  output="$(nix build --print-out-paths --no-link "${BASEDIR}#nixosConfigurations.${machine_name}.config.system.build.toplevel")"

  [[ -x "${output}/bin/switch-to-configuration" ]]
}

run_system_check() {
  case "$(uname -s)" in
    Darwin)
      verify_darwin_build
      ;;
    Linux)
      if [[ ! -e /etc/NIXOS && ! -e /run/current-system/nixos-version ]]; then
        printf 'Unsupported Linux system; expected NixOS.\n' >&2
        exit 1
      fi

      verify_nixos_build
      ;;
    *)
      printf 'Unsupported system: %s\n' "$(uname -s)" >&2
      exit 1
      ;;
  esac
}

cd "${BASEDIR}"
run_dotbot_check "$@"
run_system_check
